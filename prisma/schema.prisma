generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  content     String
  publishedAt DateTime @default(now())
  isDraft     Boolean  @default(false)
}
